{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "deployment": {
      "image": {
        "description": "Container Image",
        "properties": {
          "repositoryPrefix": {
            "type": "string"
          },
          "imagePullPolicy": {
            "type": "string"
          }
        },
        "type": "object",
        "required": [
          "repositoryPrefix"
        ]
      },
      "replicas": {
        "description": "Deployment replicas",
        "type": "integer"
      },
      "resources": {
        "description": "Container Resources consumption",
        "properties": {
          "requests": {
            "properties": {
              "cpu": {
                "type": "string"
              },
              "memory": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "limits": {
            "properties": {
              "cpu": {
                "type": "string"
              },
              "memory": {
                "type": "string"
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      },
      "type": "object",
      "required": [
        "resources",
        "replicas"
      ]
    },
    "techStack": {
      "description": "Technology used to develop the service",
      "type": "string",
      "enum": [ "nodejs", "frontend", "scala"]
    },
    "service": {
      "description": "Service properties",
      "properties": {
        "create": {
          "description": "Enable service creation",
          "type": "boolean",
          "default": false
        },
        "type": {
          "description": "Service Type",
          "type": "string",
          "enum": [ "ClusterIP", "NodePort" ],
          "default": "ClusterIP"
        },
        "containerPort": {
          "$comment": "This property shouldn't have a default value",
          "description": "Port",
          "minimum": 0,
          "type": ["integer", "null"]
        },
        "monitoringPort": {
          "description": "Monitoring Port",
          "minimum": 0,
          "type": "integer",
          "default": 9095
        },
        "managementPort": {
          "description": "Management Port",
          "minimum": 0,
          "type": "integer",
          "default": 8558
        }
      },
      "type": "object",
      "if": {
        "properties": {
          "create": { "const": true }
        }
      },
      "then": {
        "properties": {
          "portName": {
            "$comment": "This property shouldn't have a default value",
            "description": "Port Name",
            "type": ["string"]
          }
        }
      }
    },
    "name": {
      "description": "Service name",
      "type": "string"
    },
    "namespace": {
      "description": "Kubernetes namespace",
      "type": "string"
    },
    "externalSecrets": {
      "description": "External Secrets Operator configuration",
      "type": "object",
      "properties": {
        "create": {
          "description": "Enable ExternalSecret creation",
          "type": "boolean",
          "default": false
        },
        "refreshInterval": {
          "description": "Refresh interval for the secret (e.g., '1h', '30m')",
          "type": "string",
          "default": "0"
        },
        "refreshPolicy": {
          "description": "Refresh policy for the secret",
          "type": "string",
          "enum": ["OnChange", "Interval"],
          "default": "OnChange"
        },
        "secretStoreRef": {
          "description": "Reference to SecretStore or ClusterSecretStore",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the SecretStore",
              "type": "string"
            },
            "kind": {
              "description": "Kind of the store",
              "type": "string",
              "enum": ["SecretStore", "ClusterSecretStore"],
              "default": "SecretStore"
            }
          },
          "required": ["name"]
        },
        "targetSecret": {
          "description": "Target Kubernetes Secret configuration",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the target secret (defaults to microservice name)",
              "type": "string"
            },
            "creationPolicy": {
              "description": "Creation policy for the target secret",
              "type": "string",
              "enum": ["Owner", "Orphan", "Merge", "None"],
              "default": "Merge"
            },
            "deletionPolicy": {
              "description": "Deletion policy for the target secret",
              "type": "string",
              "enum": ["Retain", "Delete"],
              "default": "Retain"
            }
          }
        },
        "data": {
          "description": "List of individual secret keys to sync from external secret manager",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretKey": {
                "description": "Key name in the target Kubernetes Secret",
                "type": "string"
              },
              "remoteRef": {
                "description": "Reference to the remote secret",
                "type": "object",
                "properties": {
                  "key": {
                    "description": "Remote secret key/path",
                    "type": "string"
                  },
                  "property": {
                    "description": "Property to extract from the remote secret",
                    "type": "string"
                  },
                  "version": {
                    "description": "Version identifier for the remote secret",
                    "type": "string"
                  },
                  "conversionStrategy": {
                    "description": "Conversion strategy",
                    "type": "string"
                  },
                  "decodingStrategy": {
                    "description": "Decoding strategy",
                    "type": "string"
                  }
                },
                "required": ["key", "property"],
                "additionalProperties": false
              }
            },
            "required": ["secretKey", "remoteRef"],
            "additionalProperties": false
          },
          "default": []
        },
        "dataFrom": {
          "description": "List of sources to fetch all key/value pairs from. Each entry must contain exactly one of: extract, find, or sourceRef.",
          "type": "array",
          "items": {
            "type": "object",
            "oneOf": [
              {
                "description": "Fetch all key/value pairs from a single specific secret",
                "properties": {
                  "extract": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "description": "Remote secret key/path",
                        "type": "string"
                      },
                      "version": {
                        "description": "Version identifier for the remote secret",
                        "type": "string"
                      },
                      "property": {
                        "description": "Property to extract from the remote secret",
                        "type": "string"
                      },
                      "conversionStrategy": {
                        "description": "Conversion strategy for secret keys",
                        "type": "string",
                        "enum": ["Default", "Unicode", "PascalCase", "CamelCase", "UpperCase", "LowerCase"]
                      },
                      "decodingStrategy": {
                        "description": "Decoding strategy for secret values",
                        "type": "string",
                        "enum": ["None", "Base64", "Base64URL", "Auto"]
                      },
                      "metadataPolicy": {
                        "description": "Policy for fetching secret metadata",
                        "type": "string",
                        "enum": ["None", "Fetch"]
                      }
                    },
                    "required": ["key"],
                    "additionalProperties": false
                  },
                  "rewrite": {
                    "$ref": "#/properties/externalSecrets/definitions/rewrite"
                  }
                },
                "required": ["extract"],
                "additionalProperties": false
              },
              {
                "description": "Search for multiple secrets by name (regexp) or tags/metadata",
                "properties": {
                  "find": {
                    "type": "object",
                    "properties": {
                      "path": {
                        "description": "Search path prefix",
                        "type": "string"
                      },
                      "name": {
                        "description": "Filter by secret name using regexp",
                        "type": "object",
                        "properties": {
                          "regexp": {
                            "type": "string"
                          }
                        },
                        "required": ["regexp"],
                        "additionalProperties": false
                      },
                      "tags": {
                        "description": "Filter by tags/metadata",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "conversionStrategy": {
                        "description": "Conversion strategy for secret keys",
                        "type": "string",
                        "enum": ["Default", "Unicode", "PascalCase", "CamelCase", "UpperCase", "LowerCase"]
                      },
                      "decodingStrategy": {
                        "description": "Decoding strategy for secret values",
                        "type": "string",
                        "enum": ["None", "Base64", "Base64URL", "Auto"]
                      }
                    },
                    "additionalProperties": false
                  },
                  "rewrite": {
                    "$ref": "#/properties/externalSecrets/definitions/rewrite"
                  }
                },
                "required": ["find"],
                "additionalProperties": false
              },
              {
                "description": "Fetch values from a Generator resource",
                "properties": {
                  "sourceRef": {
                    "type": "object",
                    "properties": {
                      "generatorRef": {
                        "type": "object",
                        "properties": {
                          "apiVersion": {
                            "description": "API version of the Generator resource",
                            "type": "string"
                          },
                          "kind": {
                            "description": "Kind of the Generator resource",
                            "type": "string"
                          },
                          "name": {
                            "description": "Name of the Generator resource",
                            "type": "string"
                          }
                        },
                        "required": ["apiVersion", "kind", "name"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["generatorRef"],
                    "additionalProperties": false
                  }
                },
                "required": ["sourceRef"],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "additionalProperties": true,
      "definitions": {
        "rewrite": {
          "description": "Rewrite rules to transform secret key names",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "regexp": {
                "type": "object",
                "properties": {
                  "source": {
                    "description": "Regexp pattern to match",
                    "type": "string"
                  },
                  "target": {
                    "description": "Replacement string",
                    "type": "string"
                  }
                },
                "required": ["source", "target"],
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": [
    "name",
    "namespace",
    "techStack"
  ],
  "title": "Values",
  "type": "object"
}